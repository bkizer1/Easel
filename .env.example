# =============================================================================
# Easel — example environment file
# =============================================================================
# These variables only SEED first-run defaults for AppSettings. At runtime,
# Easel reads its configuration from persisted AppSettings and resolves any
# secrets through Electron `safeStorage` — never from raw process env. None of
# the values below are required for the default, recommended setup.
#
# Copy to `.env` and edit as needed:  cp .env.example .env
# See docs/ARCHITECTURE.md §6 "Authentication & Providers" for the full model.
# -----------------------------------------------------------------------------


# -----------------------------------------------------------------------------
# Agent backend selection
# -----------------------------------------------------------------------------
# Which pluggable AgentBackend is active. One of:
#   claude-agent-sdk  — full coding agent on @anthropic-ai/claude-agent-sdk (default)
#   anthropic-api     — hand-built loop on the raw Anthropic Messages API (always billed)
#   local-openai      — hand-built loop against an OpenAI-compatible endpoint (Ollama, LM Studio, ...)
EASEL_DEFAULT_BACKEND=claude-agent-sdk


# -----------------------------------------------------------------------------
# Default model (Claude-family backends only)
# -----------------------------------------------------------------------------
# Used by claude-agent-sdk and anthropic-api. The local-openai backend ignores
# this and uses its own configured model (see EASEL_LOCAL_OPENAI_MODEL below).
#
# Current Claude model ids (June 2026):
#   claude-opus-4-8               — Opus 4.8   (most capable)
#   claude-sonnet-4-6             — Sonnet 4.6 (recommended default)
#   claude-haiku-4-5-20251001     — Haiku 4.5  (fastest / cheapest)
EASEL_DEFAULT_MODEL=claude-sonnet-4-6


# =============================================================================
# Claude Agent SDK — authentication mode (ClaudeAuthMode)
# =============================================================================
# The claude-agent-sdk backend supports five auth modes. The DEFAULT is
# `inherit`, which is the recommended path and requires NONE of the variables
# in this section.
#
#   inherit  (DEFAULT) — Easel sets NO credential env vars and lets the SDK use
#                        whatever Claude credential already exists on the machine
#                        (e.g. an existing Claude Code login -> your Pro/Max plan).
#                        Normal use incurs no extra pay-as-you-go API spend.
#
#                        IMPORTANT / by design: Easel NEVER implements its own
#                        "Login with Claude" flow and NEVER reads ~/.claude
#                        credentials directly (Anthropic ToS forbids redistributed
#                        third-party subscription login). `inherit` simply defers
#                        to the SDK's own credential resolution.
#
#   api-key  — set ANTHROPIC_API_KEY (below). Pay-as-you-go API billing.
#   bedrock  — set CLAUDE_CODE_USE_BEDROCK=1 (+ AWS_REGION); uses ambient AWS creds.
#   vertex   — set CLAUDE_CODE_USE_VERTEX=1 (+ project/region); uses GCP ADC.
#   gateway  — set ANTHROPIC_BASE_URL (+ ANTHROPIC_AUTH_TOKEN); routes via a proxy.
# -----------------------------------------------------------------------------

# --- api-key mode (also required by the anthropic-api backend) ---------------
# Your Anthropic API key. Leave blank to stay on the default `inherit` mode.
# Stored encrypted via safeStorage once entered in Settings; this only seeds it.
# ANTHROPIC_API_KEY=sk-ant-...

# --- bedrock mode ------------------------------------------------------------
# Route the Claude Agent SDK through Amazon Bedrock. Credentials come from the
# ambient AWS credential chain (env / shared config / SSO / instance role) —
# Easel never supplies them.
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_REGION=us-east-1
# AWS_PROFILE=default

# --- vertex mode -------------------------------------------------------------
# Route the Claude Agent SDK through Google Vertex AI. Credentials come from
# Application Default Credentials (ADC) — Easel never supplies them.
# CLAUDE_CODE_USE_VERTEX=1
# CLOUD_ML_REGION=us-east5
# ANTHROPIC_VERTEX_PROJECT_ID=my-gcp-project

# --- gateway mode ------------------------------------------------------------
# Route the Claude Agent SDK through an Anthropic-compatible proxy/gateway
# (e.g. LiteLLM) to reach local or other models while keeping the SDK loop.
# ANTHROPIC_BASE_URL=http://localhost:4000
# ANTHROPIC_AUTH_TOKEN=your-gateway-bearer-token


# =============================================================================
# local-openai backend — OpenAI-compatible / offline endpoint
# =============================================================================
# Only used when EASEL_DEFAULT_BACKEND=local-openai. Runs Easel's own agent
# tool-loop against any OpenAI-compatible server (Ollama, LM Studio, llama.cpp,
# vLLM, ...). NOTE: capabilities.agenticReliability = 'variable' for this
# backend — local models may struggle with multi-step tool use, and the UI
# surfaces a warning. Claude backends are recommended for complex edits.
# -----------------------------------------------------------------------------
# Examples:
#   Ollama    -> http://localhost:11434/v1
#   LM Studio -> http://localhost:1234/v1
# EASEL_LOCAL_OPENAI_BASE_URL=http://localhost:11434/v1
# EASEL_LOCAL_OPENAI_MODEL=qwen2.5-coder:14b
# Optional bearer token if your local server requires one:
# EASEL_LOCAL_OPENAI_API_KEY=


# -----------------------------------------------------------------------------
# Optional image-generation provider (replace_image tool)
# -----------------------------------------------------------------------------
# Leave blank to use the built-in stub provider. Set a key to enable a real
# provider (e.g. DALL-E / Replicate), and toggle EASEL_FEATURE_IMAGE_GENERATION.
# IMAGE_PROVIDER_API_KEY=


# -----------------------------------------------------------------------------
# Feature flags (FeatureFlags) — conservative defaults
# -----------------------------------------------------------------------------
# Enable Web Speech API voice input in the renderer.
EASEL_FEATURE_VOICE_INPUT=true

# Enable the real image-generation provider vs. the stub
# (requires IMAGE_PROVIDER_API_KEY).
EASEL_FEATURE_IMAGE_GENERATION=false

# Show streamed agent reasoning ('thinking') in the chat panel.
EASEL_FEATURE_SHOW_THINKING=true

# Auto-create a git checkpoint before every applied edit.
EASEL_FEATURE_AUTO_CHECKPOINT=true
