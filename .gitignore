# Dependencies
node_modules/
# package-lock.json IS committed (reproducible installs + `npm ci` in CI).
# Ignore other package managers' lockfiles to avoid conflicting resolutions.
pnpm-lock.yaml
yarn.lock

# Build outputs
dist/
out/
build/
*.app/

# Environment
.env
.env.local
.env.*.local

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# OS-specific
Thumbs.db
.directory

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Coverage
coverage/
.nyc_output/

# Temporary files
*.tmp
*.bak
.turbo/

# Secrets & local runtime state — defense-in-depth.
# (Easel stores real secrets encrypted in the OS userData dir, never the repo —
#  but never commit these if they ever appear in the working tree.)
secrets.json
settings.json
*.local
.env.production
*.pem

# Generated supply-chain artifacts
sbom.cdx.json
sbom.spdx.json
