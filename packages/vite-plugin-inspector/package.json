{
  "name": "@easel/vite-plugin-inspector",
  "version": "0.1.0",
  "description": "Vite plugin that instruments JSX/HTML elements with source location metadata for Easel",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "keywords": [
    "vite",
    "plugin",
    "react",
    "source-mapping",
    "inspector",
    "easel",
    "web-development"
  ],
  "engines": {
    "node": ">=20.0.0",
    "vite": ">=5.0.0"
  },
  "scripts": {
    "build": "tsc --outDir dist",
    "dev": "tsc --outDir dist --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@babel/core": "^7.25.2",
    "@babel/generator": "^7.25.0",
    "@babel/parser": "^7.25.3",
    "@babel/traverse": "^7.25.3",
    "@babel/types": "^7.25.2"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.6.8",
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^20.14.11",
    "typescript": "^5.5.4",
    "vite": "^5.3.4"
  }
}
